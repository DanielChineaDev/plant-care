rules_version = '2';

// Reglas de seguridad de Firestore para PlantCare.
//
// Despliegue manual:
//   1. Firebase Console -> Firestore Database -> pestania Rules
//   2. Reemplaza el contenido con este fichero
//   3. Publicar
//
// O via Firebase CLI:
//   firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function onlyChanged(keys) {
      return changedKeys().hasOnly(keys);
    }
    function memberCountDelta() {
      return request.resource.data.memberCount - resource.data.memberCount;
    }
    function likeCountDelta() {
      return request.resource.data.likeCount - resource.data.likeCount;
    }
    function commentCountDelta() {
      return request.resource.data.commentCount - resource.data.commentCount;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ---------- /users ----------
    match /users/{userId} {
      // Cualquier user logueado puede leer perfiles (para mostrar avatar/nombre
      // en posts y comentarios). Solo el dueno escribe el suyo.
      allow read: if isSignedIn();
      // Al crear, isAdmin siempre arranca en false. Esto se hace solo desde
      // el primer login. Que el user no pueda autopromocionarse a admin.
      allow create: if isMe(userId)
        && request.resource.data.uid == userId
        && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false);
      // Update: el dueno escribe lo suyo pero NO puede cambiar isAdmin (solo
      // se cambia manualmente desde Firebase Console).
      allow update: if isMe(userId)
        && (!('isAdmin' in request.resource.data) ||
            request.resource.data.isAdmin == resource.data.get('isAdmin', false));
      allow delete: if isMe(userId);

      // Subcolecciones del propio user: solo el dueno.
      match /joinedCommunities/{communityId} {
        allow read, write: if isMe(userId);
      }
      match /postLikes/{postId} {
        allow read, write: if isMe(userId);
      }
      // Plantas publicas: cualquiera puede leer (solo aparecen aqui si el
      // user activo isCollectionPublic). Solo el dueno escribe.
      match /publicPlants/{plantId} {
        allow read: if true;
        allow write: if isMe(userId);
      }
      // Tokens FCM del usuario. Solo el dueno los escribe/borra. NADIE
      // los lee desde el cliente (solo el backend con Admin SDK los lee
      // para enviar pushes).
      match /fcmTokens/{token} {
        allow read: if false;
        allow write: if isMe(userId);
      }
    }

    // ---------- /communities ----------
    match /communities/{communityId} {
      // Catalogo publico: cualquiera lee, incluso sin login.
      allow read: if true;

      // Crear comunidad: solo admins. createdBy = uid, memberCount = 0.
      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberCount == 0;

      // Update solo para incrementar/decrementar memberCount en
      // transacciones de join/leave. No se pueden cambiar nombre/desc/etc.
      allow update: if isSignedIn()
        && onlyChanged(['memberCount'])
        && (memberCountDelta() == 1 || memberCountDelta() == -1);

      // Por ahora no permitimos borrar comunidades.
      allow delete: if false;

      // ---------- /communities/{c}/members ----------
      match /members/{userId} {
        allow read: if isSignedIn();
        // Solo el usuario puede crear/borrar su propia membership.
        allow create, delete: if isMe(userId);
      }

      // ---------- /communities/{c}/posts ----------
      match /posts/{postId} {
        // Feeds publicos: cualquiera lee.
        allow read: if true;

        // Crear post: logueado, authorUid = uid, contadores inicializados a 0.
        // photoUrl puede ser null o string.
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.likeCount == 0
          && request.resource.data.commentCount == 0;

        // Update solo para tocar contadores (+/- 1) por transacciones de
        // like, comentario, etc. No se pueden editar texto/foto/autor.
        allow update: if isSignedIn()
          && onlyChanged(['likeCount', 'commentCount'])
          && (likeCountDelta() == 0 || likeCountDelta() == 1 || likeCountDelta() == -1)
          && (commentCountDelta() == 0 || commentCountDelta() == 1 || commentCountDelta() == -1);

        // Solo el autor puede borrar su post.
        allow delete: if isSignedIn()
          && resource.data.authorUid == request.auth.uid;

        // ---------- /communities/{c}/posts/{p}/likes ----------
        match /likes/{userId} {
          allow read: if true;
          // Solo el propio usuario crea/borra su like.
          allow create, delete: if isMe(userId);
        }

        // ---------- /communities/{c}/posts/{p}/comments ----------
        match /comments/{commentId} {
          allow read: if true;
          // Crear: logueado, authorUid = uid.
          allow create: if isSignedIn()
            && request.resource.data.authorUid == request.auth.uid;
          // Solo el autor borra su comentario.
          allow delete: if isSignedIn()
            && resource.data.authorUid == request.auth.uid;
          // Por ahora no permitimos editar comentarios.
          allow update: if false;
        }
      }
    }

    // ---------- /notifications ----------
    // Centro de notificaciones in-app. Las crea SOLO el Admin SDK desde
    // Cloud Functions (post_like, post_comment, community_join). El cliente
    // solo lee las propias y puede actualizar el flag `read` (todo el resto
    // queda inmutable desde el cliente).
    match /notifications/{userId}/items/{notificationId} {
      allow read: if isMe(userId);
      allow create: if false; // solo backend con Admin SDK.
      allow delete: if isMe(userId);
      // Update: solo permitido cambiar el campo "read" a true/false. Asi el
      // cliente puede marcar como leida pero no inventarse notifs falsas
      // ni cambiar el contenido (fromUid, postId, etc.).
      allow update: if isMe(userId)
        && changedKeys().hasOnly(['read']);
    }

    // ---------- /conversations ----------
    // Chat 1-a-1. El id es deterministico: sorted(uidA, uidB).joinToString("_")
    match /conversations/{conversationId} {
      // Solo los participantes pueden leer y escribir la conversacion.
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      // Crear: el usuario actual debe estar en participants y este array
      // debe tener exactamente 2 elementos.
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      // Update: solo si sigues siendo participante; no se puede cambiar
      // el array participants ni los nombres/fotos almacenados.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        // Solo los participantes de la conversacion padre pueden ver y
        // crear mensajes. Usamos get() en el doc padre para comprobarlo.
        function isParticipant() {
          return isSignedIn()
            && request.auth.uid in get(
              /databases/$(database)/documents/conversations/$(conversationId)
            ).data.participants;
        }
        allow read: if isParticipant();
        allow create: if isParticipant()
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }
    }
  }
}
