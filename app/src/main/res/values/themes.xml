<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PlantCare" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Sin splash nativo: la ventana de arranque es solo un color de marca
             (evita el flash blanco). El splash real con el logo lo pinta Compose
             (SplashScreen), que ademas controla cuando desaparecer. -->
        <item name="android:windowBackground">@color/brand_green_muted</item>
        <item name="android:statusBarColor">@color/brand_green_muted</item>
        <item name="android:navigationBarColor">@color/brand_green_muted</item>
    </style>
</resources>
