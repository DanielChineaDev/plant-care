<?xml version="1.0" encoding="utf-8"?>
<!--
  Logo de PlantCare: hoja estilizada sobre fondo circular verde con
  una gota de agua en la base. Vector escalable, 192x192 viewport.
  Usado en el drawer header, login, register y empty states.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="192dp"
    android:height="192dp"
    android:viewportWidth="192"
    android:viewportHeight="192">

    <!-- Circulo de fondo (verde primary) -->
    <path
        android:fillColor="#2E7D32"
        android:pathData="M96,96 m-92,0 a92,92 0 1,0 184,0 a92,92 0 1,0 -184,0" />

    <!-- Hoja principal (forma de gota inversa) en blanco -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M96,38
            C 80,58 60,72 60,100
            C 60,124 76,142 96,142
            C 116,142 132,124 132,100
            C 132,72 112,58 96,38 Z" />

    <!-- Nervio central de la hoja, en verde mas oscuro -->
    <path
        android:fillColor="#1B5E20"
        android:strokeColor="#1B5E20"
        android:strokeWidth="3"
        android:pathData="M96,52
            L 96,134" />

    <!-- Gotita en la punta inferior, color azul claro -->
    <path
        android:fillColor="#81D4FA"
        android:pathData="M96,150
            C 90,158 90,168 96,168
            C 102,168 102,158 96,150 Z" />
</vector>
