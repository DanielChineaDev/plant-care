<?xml version="1.0" encoding="utf-8"?>
<!--
  Logo de PlantCare: brote de dos hojas en blanco sobre un circulo con
  degradado verde. Vector escalable, viewport 192x192. Usado en el drawer
  header, login/registro y empty states (fondos claros).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="192dp"
    android:height="192dp"
    android:viewportWidth="192"
    android:viewportHeight="192">

    <!-- Circulo de fondo con degradado verde -->
    <path android:pathData="M96,96 m-92,0 a92,92 0 1,0 184,0 a92,92 0 1,0 -184,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="20"
                android:startY="20"
                android:endX="172"
                android:endY="172">
                <item android:color="#FF43A047" android:offset="0.0" />
                <item android:color="#FF2E7D32" android:offset="0.55" />
                <item android:color="#FF1B5E20" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tallo central -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:pathData="M96,150 L96,103" />

    <!-- Hoja derecha -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M96,104 C103,82 121,68 142,64 C139,87 124,101 96,104 Z" />

    <!-- Hoja izquierda -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M96,104 C89,82 71,68 50,64 C53,87 68,101 96,104 Z" />

    <!-- Nervios sutiles -->
    <path
        android:strokeColor="#B3FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M98,100 L130,72" />
    <path
        android:strokeColor="#B3FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M94,100 L62,72" />
</vector>
