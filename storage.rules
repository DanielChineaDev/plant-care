rules_version = '2';

// Reglas de seguridad de Firebase Storage para PlantCare.
//
// Despliegue manual:
//   1. Firebase Console -> Storage -> pestania Rules
//   2. Reemplaza el contenido con este fichero
//   3. Publicar
//
// O via Firebase CLI:
//   firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de posts de comunidades. Path: community_posts/{communityId}/{postId}.jpg
    match /community_posts/{communityId}/{fileName} {
      // Cualquiera puede ver fotos de posts (feed publico).
      allow read: if true;
      // Solo logueados pueden subir, max 5 MB, content-type imagen.
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Portada de comunidades. Path: communities/{communityId}/cover.jpg
    // Lo sube solo quien acaba de crear la comunidad (Firestore valida que
    // sea admin). Aqui ya no tenemos contexto del Firestore asi que basta
    // con "logueado, max 5MB, imagen".
    match /communities/{communityId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Fotos de chat. Path: chat_photos/{conversationId}/{fileName}.jpg
    // Solo logueados leen/suben (el conversationId no permite validar
    // participantes aqui, pero la coleccion Firestore si lo hace). Max 5 MB.
    match /chat_photos/{conversationId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Avatares de usuario. Path: avatars/{uid}/{fileName}.jpg
    match /avatars/{uid}/{fileName} {
      // Cualquiera puede ver los avatares (aparecen en posts, comentarios,
      // chats, etc. que son publicos / visibles entre logueados).
      allow read: if true;
      // Solo el dueno sube/borra el suyo. Max 2 MB, content-type imagen.
      allow write: if request.auth != null
        && request.auth.uid == uid
        && (request.resource == null ||
            (request.resource.size < 2 * 1024 * 1024
             && request.resource.contentType.matches('image/.*')));
    }

    // Por defecto: nada accesible. Se ira abriendo a medida que metamos
    // mas features (avatares custom, fotos privadas de plantas, etc.).
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
